new file mode 100644
index 0000000..88e1746
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,100 @@
+name: CI
+
+on:
+  push:
+    branches: [main, develop]
+  pull_request:
+    branches: [main, develop]
+
+jobs:
+  # ─── Engine Build & Type Check ────────────────────────────────────────────────
+  engine-build:
+    name: Engine Build & Type Check
+    runs-on: ubuntu-latest
+    defaults:
+      run:
+        working-directory: ecobe-engine
+
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+          cache: 'npm'
+          cache-dependency-path: ecobe-engine/package-lock.json
+
+      - name: Install dependencies
+        run: npm ci
+
+      - name: Prisma generate
+        run: npx prisma generate
+        env:
+          DATABASE_URL: 'postgresql://placeholder:placeholder@localhost:5432/placeholder'
+
+      - name: TypeScript type check
+        run: npm run type-check
+
+      - name: Build
+        run: npm run build
+        env:
+          DATABASE_URL: 'postgresql://placeholder:placeholder@localhost:5432/placeholder'
+
+      - name: Run tests
+        run: npm test -- --passWithNoTests
+        env:
+          DATABASE_URL: 'postgresql://placeholder:placeholder@localhost:5432/placeholder'
+          NODE_ENV: test
+
+  # ─── Dashboard Build & Type Check ─────────────────────────────────────────────
+  dashboard-build:
+    name: Dashboard Build & Type Check
+    runs-on: ubuntu-latest
+    defaults:
+      run:
+        working-directory: ecobe-dashboard
+
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Setup Node.js
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+          cache: 'npm'
+          cache-dependency-path: ecobe-dashboard/package-lock.json
+
+      - name: Install dependencies
+        run: npm ci
+
+      - name: TypeScript type check
+        run: npx tsc --noEmit
+
+      - name: Build
+        run: npm run build
+        env:
+          ECOBE_API_URL: 'http://localhost:3000'
+          NEXT_PUBLIC_ECOBE_API_URL: '/api/ecobe'
+
+      - name: Verify standalone output
+        run: |
+          test -f .next/standalone/server.js || (echo "Error: standalone server.js not found" && exit 1)
+          echo "Standalone build verified"
+
+  # ─── CI Gate ──────────────────────────────────────────────────────────────────
+  ci-status:
+    name: CI Status
+    runs-on: ubuntu-latest
+    needs: [engine-build, dashboard-build]
+    if: always()
+
+    steps:
+      - name: Check results
+        run: |
+          if [ "${{ needs.engine-build.result }}" == "failure" ] || \
+             [ "${{ needs.dashboard-build.result }}" == "failure" ]; then
+            echo "CI failed"
+            exit 1
+          fi
+          echo "All CI checks passed"
