PORT=3004
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Runtime: Prisma Accelerate (connection pooling + cache)
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
# Migrations: Direct Neon connection
DIRECT_DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Prisma Optimize (query monitoring)
OPTIMIZE_API_KEY=your_optimize_jwt_token

# ─── Redis (Upstash TLS) ─────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@host.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://host.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token

# ─── QStash (Upstash) ────────────────────────────────────────────────────────
QSTASH_TOKEN=your_qstash_token
QSTASH_BASE_URL=https://qstash-us-east-1.upstash.io
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ─── Upstash Search ──────────────────────────────────────────────────────────
UPSTASH_SEARCH_REST_URL=https://host-search.upstash.io
UPSTASH_SEARCH_REST_TOKEN=your_search_token

# ─── Carbon Providers ─────────────────────────────────────────────────────────
ELECTRICITY_MAPS_API_KEY=
ELECTRICITY_MAPS_BASE_URL=https://api.electricitymap.org
DEFAULT_MAX_CARBON_G_PER_KWH=400
WATTTIME_USERNAME=
WATTTIME_PASSWORD=
EMBER_API_KEY=
EMBER_BASE_URL=https://api.ember-climate.org
EIA_API_KEY=
EIA_BASE_URL=https://api.eia.gov

# ─── Grid Signal Cache ───────────────────────────────────────────────────────
GRID_SIGNAL_CACHE_TTL=900
GRID_FEATURE_CACHE_TTL=3600
EIA_INGESTION_SCHEDULE=0 */15 * * * *
EIA_BACKFILL_ENABLED=true

# —— Autonomy / self-heal / learning loops ————————————————————————————————————
LEARNING_LOOP_ENABLED=true
LEARNING_LOOP_CRON=*/15 * * * *
LEARNING_LOOKBACK_HOURS=168
RUNTIME_SUPERVISOR_ENABLED=true
RUNTIME_SUPERVISOR_INTERVAL_SEC=60
SUPERVISOR_FORECAST_STALE_MIN=90
SUPERVISOR_INTELLIGENCE_STALE_MIN=90
SUPERVISOR_LEARNING_STALE_MIN=120

# ─── DEKES SaaS Integration ──────────────────────────────────────────────────
# Shared API key — must match DEKES_API_KEY (or ECOBE_API_KEY) on the DEKES SaaS side
DEKES_API_KEY=
# Webhook URL to push events to DEKES SaaS (budget, policy, handoff status)
DEKES_WEBHOOK_URL=http://localhost:3000/api/ecobe/event
# Webhook secret — sent in body.secret field for webhook verification
DEKES_WEBHOOK_SECRET=

# Decision event outbox / signed sink delivery
# The self-verifier route validates against DECISION_API_SIGNATURE_SECRET.
# The dispatcher will prefer that same secret, then fall back to DECISION_EVENT_SIGNATURE_SECRET.
DECISION_EVENT_DISPATCH_ENABLED=true
DECISION_EVENT_DISPATCH_CRON=*/20 * * * * *
DECISION_EVENT_DISPATCH_BATCH_SIZE=25
DECISION_EVENT_DISPATCH_TIMEOUT_MS=3000
DECISION_EVENT_MAX_ATTEMPTS=5
DECISION_EVENT_RETRY_BASE_MS=1000
DECISION_EVENT_SIGNATURE_SECRET=
DECISION_EVENT_ALERT_LAG_MINUTES=10
DECISION_EVENT_ALERT_FAILURE_RATE_PCT=20
DECISION_EVENT_ALERT_DEADLETTER_COUNT=25
SUPERVISOR_DECISION_EVENT_STALE_MIN=30

# Optional pre-decision external policy hook
EXTERNAL_POLICY_HOOK_ENABLED=false
EXTERNAL_POLICY_HOOK_URL=
EXTERNAL_POLICY_HOOK_AUTH_TOKEN=
EXTERNAL_POLICY_HOOK_TIMEOUT_MS=800
EXTERNAL_POLICY_HOOK_STRICT_PROFILES=drought_sensitive,eu_data_center_reporting,high_water_sensitivity

# SEKED policy adapter
# Leave URL blank to run the canonical internal evaluator (SEKED_INTERNAL_V1)
SEKED_POLICY_ADAPTER_ENABLED=true
SEKED_POLICY_ADAPTER_URL=
SEKED_POLICY_ADAPTER_AUTH_TOKEN=
SEKED_POLICY_ADAPTER_TIMEOUT_MS=800
SEKED_POLICY_ADAPTER_STRICT_PROFILES=drought_sensitive,eu_data_center_reporting,high_water_sensitivity

# Internal/admin routes
UI_ENABLED=false
UI_TOKEN=
ENGINE_BACKGROUND_WORKERS_ENABLED=true
ECOBE_INTERNAL_API_KEY=
ECOBE_TRUSTED_BROKER_ID=ecobe-mvp
ECOBE_ENFORCE_BROKER_ID=true

# Dashboard/automation callers
ECOBE_ENGINE_URL=
ECOBE_ENGINE_API_KEY=

# Decision API signing / tenancy / billing
DECISION_API_SIGNATURE_SECRET=
JWT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_GROWTH_MONTHLY_PRICE_ID=
STRIPE_GROWTH_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# OTLP-aligned observability
OTEL_EXPORT_ENABLED=false
OTEL_EXPORT_ENDPOINT=
OTEL_SERVICE_NAME=ecobe-engine
