{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ECOBE Engine",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/.bin/tsx", "watch", "src/server.ts"],
      "port": 3000,
      "autoPort": true,
      "cwd": "ecobe-engine"
    },
    {
      "name": "ECOBE Dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "port": 3001,
      "autoPort": true,
      "cwd": "ecobe-dashboard"
    }
  ]
}
