# ECOBE Engine API URL (used by Next.js route handler proxy)
ECOBE_API_URL=http://localhost:3000
ECOBE_INTERNAL_API_KEY=

# Required for dashboard-side trace/replay/internal control-surface routes
ECOBE_INTERNAL_API_KEY=

# Required if the dashboard will initiate or proxy signed decision requests to the engine
DECISION_API_SIGNATURE_SECRET=

# Optional: if you want the browser to call the engine directly (not recommended)
NEXT_PUBLIC_ECOBE_API_URL=

# Resend mail configuration
RESEND_API_KEY=
RESEND_FROM_CONTACT="CO2 Router <notifications@co2router.com>"
RESEND_FROM_ALERTS="CO2 Router Alerts <alerts@co2router.com>"
CONTACT_INBOX_EMAIL=affirmandthriveco@gmail.com
ALERT_INBOX_EMAIL=affirmandthriveco@gmail.com
