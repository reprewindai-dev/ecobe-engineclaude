{
  "name": "co2router",
  "version": "1.0.0",
  "description": "Carbon-aware compute routing and scheduling — route workloads to cleaner energy grids automatically.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "node -e \"console.log('CO2ROUTER_URL present:', Boolean(process.env.CO2ROUTER_URL))\"",
    "build": "tsc && prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "start": "npm run prisma:migrate:deploy && node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run prisma:migrate:deploy && npm run prisma:seed",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "carbon",
    "carbon-routing",
    "carbon-aware",
    "green-computing",
    "emissions",
    "sustainability",
    "co2",
    "scheduling"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "0.0.33",
    "@langchain/openai": "0.0.14",
    "@prisma/client": "^7.4.2",
    "@prisma/extension-accelerate": "^3.0.1",
    "@prisma/instrumentation": "^7.4.2",
    "@types/axios": "^0.9.36",
    "@upstash/qstash": "^2.9.0",
    "@upstash/redis": "^1.36.3",
    "@upstash/vector": "1.1.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "date-fns": "^3.3.0",
    "dotenv": "^16.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.4.1",
    "langchain": "0.3.0",
    "node-cron": "^4.2.1",
    "openai": "^4.28.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.4.2",
    "redis": "^4.6.0",
    "stripe": "^20.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
