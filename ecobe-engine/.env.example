PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://ecobe:ecobe@localhost:5432/ecobe
DIRECT_URL=
REDIS_URL=redis://localhost:6379

ELECTRICITY_MAPS_API_KEY=
ELECTRICITY_MAPS_BASE_URL=https://api.electricitymap.org
DEFAULT_MAX_CARBON_G_PER_KWH=400

# Multi-provider carbon data layer
# Add API keys for additional providers to enable fallback, validation, and history enrichment.
# Keys are NEVER exposed client-side — server only.
EMBER_ENERGY_API_KEY=
EMBER_BASE_URL=https://api.ember-climate.org/v2
WATTTIME_API_KEY=

# Provider roles: primary_realtime | secondary_validation | secondary_history | fallback | disabled
CARBON_PROVIDER_PRIMARY=electricity_maps
CARBON_PROVIDER_VALIDATION=ember
CARBON_PROVIDER_ALLOW_FALLBACK=true
CARBON_PROVIDER_MAX_STALENESS_MINUTES=10
CARBON_PROVIDER_DISAGREEMENT_THRESHOLD_PCT=15
# Set to true in dev to see per-request provider decisions in the console
CARBON_PROVIDER_DEV_DIAGNOSTICS=false

DEKES_API_URL=
DEKES_API_KEY=

# Governance
GOVERNANCE_AUDIT_ENABLED=true
GOVERNANCE_CHAIN_VERIFY=false

# Set to true ONLY in development to allow unauthenticated access when ECOBE_ENGINE_API_KEY is unset.
# Never set this in production.
ALLOW_INSECURE_NO_API_KEY=false
