generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// CARBON INTENSITY DATA
// ============================================================================

model CarbonIntensity {
  id        String   @id @default(cuid())

  region    String   // e.g., "US-CAL-CISO", "FR", "DE"

  // Carbon metrics
  carbonIntensity      Int      // gCO2eq/kWh
  fossilFuelPercentage Float?
  renewablePercentage  Float?

  // Source
  source    String   @default("ELECTRICITY_MAPS")

  // Native resolution — store data exactly as received; do NOT normalize to a uniform interval.
  // 5 = 5-minute readings, 15 = 15-minute readings, 60 = hourly (default).
  // Alignment to a common resolution happens at query time inside DecisionDataAssembler.
  resolutionMinutes Int @default(60)

  // Timestamp
  timestamp DateTime

  // Metadata
  isEstimated Boolean  @default(false)
  metadata    Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([region, timestamp])
  @@index([timestamp])
  @@unique([region, timestamp], name: "region_timestamp")
  @@unique([region, timestamp, source], name: "region_timestamp_source")
}

// ============================================================================
// WORKLOAD ROUTING
// ============================================================================

model WorkloadRequest {
  id        String   @id @default(cuid())

  // Request details
  requestVolume Int
  workloadType  String   // "inference", "training", "batch"
  modelSize     String?  // "mixtral-70b", "llama-3-8b", etc.

  // Routing
  regionTargets String[] // Preferred regions

  // Constraints
  carbonBudget     Float?  // Max gCO2eq allowed
  deadlineStart    DateTime?
  deadlineEnd      DateTime?
  maxLatencyMs     Int?

  // Hardware mix (optional)
  hardwareCpu      Float?  @default(0.6)
  hardwareGpu      Float?  @default(0.3)
  hardwareTpu      Float?  @default(0.1)

  // Results
  selectedRegion   String?
  estimatedCO2     Float?
  actualCO2        Float?

  // Status
  status    WorkloadStatus @default(PENDING)

  // Timestamps
  createdAt DateTime @default(now())
  completedAt DateTime?

  routingDecisions RoutingDecision[]

  @@index([status])
  @@index([createdAt])
}

enum WorkloadStatus {
  PENDING
  ROUTED
  EXECUTING
  COMPLETED
  FAILED
}

model RoutingDecision {
  id        String   @id @default(cuid())

  workloadRequestId String
  workloadRequest   WorkloadRequest @relation(fields: [workloadRequestId], references: [id], onDelete: Cascade)

  region            String
  rank              Int      // 1 = best choice

  // Metrics at decision time
  carbonIntensity   Int      // gCO2eq/kWh
  estimatedCO2      Float    // Total gCO2eq
  estimatedLatency  Int?     // ms
  estimatedCost     Float?   // USD

  // Score components
  carbonScore       Float
  latencyScore      Float
  costScore         Float
  overallScore      Float

  selected          Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([workloadRequestId])
  @@index([region])
}

model DashboardRoutingDecision {
  id        String   @id @default(cuid())

  createdAt      DateTime @default(now())
  organizationId String?  // scopes decision to an org; null = legacy/anonymous

  workloadName String?
  opName       String?

  baselineRegion String
  chosenRegion   String

  zoneBaseline String?
  zoneChosen   String?

  carbonIntensityBaselineGPerKwh Int?
  carbonIntensityChosenGPerKwh   Int?

  estimatedKwh Float?
  co2BaselineG Float?
  co2ChosenG   Float?

  reason String?

  latencyEstimateMs Int?
  latencyActualMs   Int?

  fallbackUsed        Boolean @default(false)
  dataFreshnessSeconds Int?
  requestCount         Int   @default(1)

  meta Json @default("{}")

  // Links this record back to the routing decision that produced it.
  // Unique — prevents duplicate rows when both engine auto-write and client POST /decisions run.
  decisionFrameId String? @unique

  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([baselineRegion])
  @@index([chosenRegion])
}

// ============================================================================
// CARBON FORECASTING (ML Model)
// ============================================================================

model CarbonForecast {
  id        String   @id @default(cuid())

  region    String
  source    String   @default("electricity_maps")  // which provider generated this prediction

  // Forecast
  forecastTime      DateTime
  predictedIntensity Int     // gCO2eq/kWh
  confidence         Float   // 0.0 - 1.0

  // Two-time model (critical for forecast accuracy):
  //   referenceTime = when this forecast was generated / data was observed
  //   forecastTime  = the future moment being predicted (targetTime in queries)
  // Separating these lets DecisionDataAssembler pick the freshest forecast
  // for any given targetTime rather than relying on insertion order.
  referenceTime     DateTime @default(now())

  // Horizon in hours at prediction time (derived from forecastTime - referenceTime)
  horizonHours      Float    @default(0)

  // Model info
  modelVersion      String  @default("v1.0")
  features          Json    @default("{}")

  // Actual (for training / back-test) — filled in by reconcileForecastActuals
  actualIntensity   Int?
  error             Float?  // signed error: predicted - actual

  createdAt DateTime @default(now())

  @@index([region, forecastTime])
  @@index([region, referenceTime])
  @@index([forecastTime])
  @@index([region, source, forecastTime])
  // Allow multiple sources per (region, forecastTime) — source is the differentiator
  @@unique([region, forecastTime, source], name: "region_forecastTime_source")
}

/**
 * Rolling accuracy scorecard per region, recomputed after each reconciliation run.
 * Stored so the assembler can read it cheaply without a full aggregate query.
 */
model RegionForecastScorecard {
  id     String @id @default(cuid())
  region String @unique

  // MAE = mean absolute error (gCO2/kWh)
  mae24h   Float?  // 0–24 h horizon
  mae48h   Float?  // 24–48 h horizon
  mae72h   Float?  // 48–72 h horizon

  // MAPE = mean absolute percentage error (0–1)
  mape24h  Float?
  mape48h  Float?
  mape72h  Float?

  // Operational health rates (0–1, fraction of attempts)
  fallbackRate          Float  @default(0)   // predictions that used historical fallback
  staleRejectionRate    Float  @default(0)   // predictions where fresh forecast was unavailable
  providerDisagreementRate Float @default(0) // predictions with disagreement_flag set
  forecastHitRate       Float  @default(0)  // fraction where predicted best slot was actually best

  // Reliability tier derived from combined metrics
  // 'high'    → mape24h < 10%, low fallback rate
  // 'medium'  → mape24h 10–25%
  // 'low'     → mape24h > 25% or high fallback rate
  // 'unknown' → fewer than MIN_SAMPLE_COUNT observations
  reliabilityTier  String  @default("unknown")
  sampleCount      Int     @default(0)
  lastComputedAt   DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([region])
}

model ForecastRefresh {
  id        String   @id @default(cuid())

  region    String
  refreshedAt DateTime @default(now())

  recordsIngested    Int      @default(0)
  forecastsGenerated Int      @default(0)
  status             ForecastRefreshStatus @default(SUCCESS)
  message            String?

  createdAt DateTime @default(now())

  @@index([region, refreshedAt])
  @@index([refreshedAt])
}

enum ForecastRefreshStatus {
  SUCCESS
  FAILURE
}

// ============================================================================
// CARBON CREDITS & TRACKING
// ============================================================================

model CarbonCredit {
  id        String   @id @default(cuid())

  organizationId String?

  amountCO2      Float
  provider       String
  priceUsd       Float
  certificateUrl String?

  status     CarbonCreditStatus @default(ACTIVE)
  purchasedAt DateTime          @default(now())
  retiredAt   DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([status])
  @@index([purchasedAt])
}

enum CarbonCreditStatus {
  ACTIVE
  RETIRED
}

model EmissionLog {
  id        String   @id @default(cuid())

  organizationId   String?
  workloadRequestId String?

  emissionCO2 Float
  offsetCO2   Float @default(0)

  region    String
  source    String
  timestamp DateTime

  metadata  Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([workloadRequestId])
  @@index([region, timestamp])
  @@index([timestamp])
}

// ============================================================================
// DEKES INTEGRATION
// ============================================================================

model DekesWorkload {
  id        String   @id @default(cuid())

  // DEKES query info
  dekesQueryId      String?
  dekesRunId        String?
  queryString       String?

  // Workload characteristics
  estimatedQueries  Int
  estimatedResults  Int

  // Carbon optimization
  carbonBudget      Float?   // gCO2eq
  scheduledTime     DateTime?

  // Selected routing
  selectedRegion    String?
  actualCO2         Float?

  // Status
  status            String   @default("PENDING")

  createdAt DateTime @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([dekesQueryId])
}

// ============================================================================
// DEKES INTEGRATION — HANDOFF EVENTS
// ============================================================================

/**
 * Records every ECOBE → DEKES handoff event.
 * Events are always persisted here first. If DEKES_ENDPOINT is configured,
 * the sender service also HTTP-POSTs to DEKES and updates status/sentAt.
 * DEKES status callbacks update this row via POST /api/v1/integrations/dekes/handoff-status.
 *
 * Architectural rule: this table is append-only from the ECOBE side.
 * DEKES never modifies ECOBE routing decisions.
 */
model DekesHandoff {
  id              String   @id @default(cuid())
  handoffId       String   @unique            // "hof_<timestamp>_<hex>" — idempotency key

  organizationId  String?
  decisionId      String?                     // DashboardRoutingDecision.id
  decisionFrameId String?                     // For /api/v1/route/:id/replay link

  eventType       String                      // BUDGET_WARNING | BUDGET_EXCEEDED | POLICY_DELAY
  severity        String                      // low | medium | high | critical
  payloadJson     Json                        // Full handoff payload (spec v1 section 4)

  status          String   @default("queued") // queued | processing | processed | ignored | failed

  // DEKES classification fields — populated via status callback
  dekesClassification String?                 // opportunity | informational | risk | no_action
  dekesActionType     String?
  dekesActionId       String?

  // Lifecycle timestamps
  sentAt          DateTime?                   // When HTTP POST to DEKES was attempted
  processedAt     DateTime?
  failedAt        DateTime?
  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([status, createdAt])
  @@index([eventType, createdAt])
}

// ============================================================================
// CARBON BUDGET / QUOTA TRACKING
// ============================================================================

/**
 * Per-organization CO2 quota for a billing/reporting period.
 * consumedCO2Grams is atomically incremented after each routing decision.
 * Multiple non-overlapping periods may exist; only the one where
 * periodStart <= now <= periodEnd is active.
 */
model CarbonBudget {
  id             String   @id @default(cuid())
  organizationId String

  budgetPeriod   String   // 'monthly' | 'quarterly' | 'annual'
  periodStart    DateTime
  periodEnd      DateTime

  budgetCO2Grams      Float              // total allowed gCO2 for the period
  consumedCO2Grams    Float  @default(0) // incremented by consumeBudget()
  warningThresholdPct Float  @default(0.8) // emit warning at this fraction (default 80%)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, periodEnd])
  @@index([periodEnd])
}

// ============================================================================
// REGION METADATA
// ============================================================================

model Region {
  id        String   @id @default(cuid())

  code      String   @unique  // "US-CAL-CISO", "FR", etc.
  name      String            // "California", "France"
  country   String

  // Characteristics
  typicalLatencyMs  Int?
  costPerKwh        Float?
  availableHardware String[] @default([])

  // Grid mix
  renewableCapacity Float?   // %
  avgCarbonIntensity Int?    // gCO2eq/kWh

  // Availability
  enabled   Boolean  @default(true)

  metadata  Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model DailyMetrics {
  id        String   @id @default(cuid())

  date      DateTime @unique

  // Workload stats
  totalWorkloads    Int     @default(0)
  totalCO2Grams     Float   @default(0)
  totalEnergyKwh    Float   @default(0)

  // Savings
  savedCO2Grams     Float   @default(0)  // vs baseline
  savedCostUsd      Float   @default(0)

  // Avg metrics
  avgCarbonIntensity Float?

  createdAt DateTime @default(now())

  @@index([date])
}

// ============================================================================
// INTEGRATION HEALTH METRICS
// ============================================================================

model IntegrationMetric {
  id             String   @id @default(cuid())

  source         String   @unique
  successCount   Int      @default(0)
  failureCount   Int      @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  lastError      String?

  // Phase 2C: rolling latency tracking
  totalLatencyMs Float    @default(0)   // sum of all recorded latencies
  totalCalls     Int      @default(0)   // successCount + failureCount (maintained separately for accuracy)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================================
// GOVERNANCE LAYER
// ============================================================================

// Tamper-evident audit log — every write is chained via SHA256
model GovernanceAuditLog {
  id             String   @id @default(cuid())
  sequence       Int      // monotonically increasing

  organizationId String?
  actorId        String?  // SHA256 of API key — raw key never stored
  actorType      String   // "API_KEY" | "SYSTEM" | "CRON"

  action         String   // "DECISION_CREATED" | "CREDIT_RETIRED" | "CREDIT_PURCHASED" | "CREDIT_AUTO_OFFSET" | "POLICY_UPDATED" | "ANOMALY_DETECTED" | "CHAIN_VERIFIED"
  entityType     String   // "DashboardRoutingDecision" | "CarbonCredit" | "EmissionLog" | "OrganizationPolicy"
  entityId       String

  payload        Json     // snapshot of the entity at event time
  result         String   // "SUCCESS" | "FAILURE" | "BLOCKED"

  // Tamper-evident chain
  chainHash      String   // SHA256(previousHash|sequence|entityId|action|JSON(payload)|createdAt.toISOString())
  previousHash   String?  // null only for genesis record

  // Governance context
  carbonSavedG   Float?
  riskTier       String?
  policyVersion  String   @default("1.0")

  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([sequence])
  @@index([chainHash])
}

// Per-organization governance policy — carbon ceilings, routing requirements, anomaly thresholds
model OrganizationPolicy {
  id             String   @id @default(cuid())
  organizationId String   @unique

  tier           String   @default("STANDARD") // "BASIC" | "STANDARD" | "PREMIUM" | "INVESTOR_GRADE"

  // Carbon policy
  maxCarbonGPerKwh      Int?
  requireGreenRouting   Boolean @default(false)
  autoOffsetEnabled     Boolean @default(false)
  autoOffsetThresholdG  Float?

  // Audit settings
  auditRetentionDays    Int     @default(365)
  requireChainVerify    Boolean @default(false)

  // Anomaly detection
  anomalyDetectionEnabled Boolean @default(true)
  anomalyThresholdSigma   Float   @default(2.0)

  policyVersion  String   @default("1.0")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Point-in-time investor summary snapshot
model GovernanceSnapshot {
  id             String   @id @default(cuid())
  organizationId String?

  snapshotType   String   // "DAILY_SUMMARY" | "COMPLIANCE_REPORT" | "INVESTOR_BRIEF"
  windowStart    DateTime
  windowEnd      DateTime

  totalDecisions      Int   @default(0)
  greenRoutedCount    Int   @default(0)
  totalCO2SavedG      Float @default(0)
  totalCO2EmittedG    Float @default(0)
  totalCreditsActive  Float @default(0)
  totalCreditsRetired Float @default(0)
  offsetPercentage    Float @default(0)

  chainIntact      Boolean  @default(true)
  chainVerifiedAt  DateTime?
  auditLogCount    Int      @default(0)

  complianceScore  Float    @default(0)  // 0.0–1.0

  payload          Json     @default("{}")
  createdAt        DateTime @default(now())

  @@index([organizationId, snapshotType, windowStart])
  @@index([snapshotType, createdAt])
}

// ============================================================================
// PER-ORG API KEY ISOLATION
// ============================================================================

// Hashed API key tied to a single organization.
// One org may have multiple active keys (rotation support).
// keyHash = SHA-256(plaintext key) — plaintext is never stored.
// keyPrefix = first 8 chars of plaintext for display ("co2r_abc...").
model OrgApiKey {
  id             String   @id @default(cuid())
  organizationId String

  keyHash   String   @unique // SHA-256 of the raw key
  keyPrefix String            // first 8 chars of raw key — display only

  active    Boolean  @default(true)
  label     String?           // optional human label

  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([organizationId, active])
  @@index([keyHash])
}

// ============================================================================
// DECISION REPLAY (deterministic routing reconstruction)
// ============================================================================

// Full decision snapshot stored at routing time.
// Enables GET /api/v1/decisions/:id/replay to reconstruct any past decision.
model DecisionSnapshot {
  id             String   @id @default(cuid()) // = decisionFrameId from routing result

  organizationId String?
  createdAt      DateTime @default(now())

  // Request inputs
  regions          Json   // string[]
  targetTime       DateTime?
  durationMinutes  Int?
  maxCarbonGPerKwh Int?
  weights          Json   // { carbon, latency, cost }

  // Signals at decision time — keyed by region
  signalSnapshot   Json   // Record<region, { intensity, source, referenceTime, fallbackUsed, disagreementFlag }>

  // Decision output
  selectedRegion      String
  carbonIntensity     Int
  baselineIntensity   Int
  carbonDeltaGPerKwh  Int
  qualityTier         String
  forecastStability   String?
  score               Float
  explanation         String

  // Provenance
  sourceUsed          String?
  referenceTime       DateTime?
  fallbackUsed        Boolean @default(false)
  providerDisagreement Boolean @default(false)

  // Workload source context — stored at decision time for audit and replay fidelity
  source                String?  // "DEKES" | "API" | "CLI"
  workloadType          String?  // "lead_generation_batch" | "inference" | etc.
  policyMode            String?  // "balanced_ops" | "strict_carbon" | "budget_recovery"
  delayToleranceMinutes Int?     // minutes caller can wait before execution

  // Window prediction captured at decision time
  predictedCleanWindow  Json?    // null when no prediction was available

  @@index([organizationId, createdAt])
  @@index([selectedRegion, createdAt])
}

// ============================================================================
// TEMPORAL CARBON INTELLIGENCE
// Learned per-region hourly intensity patterns — what Google's scheduler lacks.
// Built from historical CarbonIntensity records; enables probability-weighted
// routing decisions rather than purely reactive signal-following.
// ============================================================================

// 168 rows per region (7 days × 24 hours, Monday=0 through Sunday=167).
// Populated/refreshed by computeTemporalPatterns() — typically nightly.
model RegionTemporalPattern {
  id         String @id @default(cuid())
  region     String
  hourOfWeek Int    // 0 = Mon 00:00 UTC … 167 = Sun 23:00 UTC

  avgIntensity Float
  p10Intensity Float  // optimistic / clean end of distribution
  p50Intensity Float  // median
  p90Intensity Float  // pessimistic / dirty end
  stddev       Float

  sampleCount Int

  updatedAt DateTime @updatedAt

  @@unique([region, hourOfWeek])
  @@index([region])
}

// ============================================================================
// DECISION LEASE (execution drift prevention)
// Prevents stale decisions from executing after grid/policy state has changed.
// ============================================================================

// Execution validity window attached to every routed decision.
// Status lifecycle: VALID → REVALIDATED | EXECUTED | EXPIRED | DRIFT_BLOCKED
model DecisionLease {
  id             String  @id // = decisionFrameId from routing result
  organizationId String?

  createdAt DateTime @default(now())

  // Original request inputs — used to re-route on revalidation
  regions          Json   // string[]
  maxCarbonGPerKwh Int?
  weights          Json   // { carbon, latency, cost }
  qualityTier      String // high | medium | low

  // Lease window boundaries
  leaseExpiresAt         DateTime
  revalidationRequiredAt DateTime

  // Decision at creation time
  selectedRegion  String
  carbonIntensity Int

  // Workload source context — preserved for revalidation context
  source       String?
  workloadType String?

  // Current status
  status String @default("VALID") // VALID | REVALIDATED | EXECUTED | EXPIRED | DRIFT_BLOCKED

  // Revalidation outcome (populated when POST /:id/revalidate is called)
  revalidatedAt      DateTime?
  revalidationAction String?   // execute | reroute | delay | deny
  revalidationReason String?
  driftDetected      Boolean   @default(false)
  newRegion          String?   // populated when rerouted

  @@index([organizationId, createdAt])
  @@index([status, leaseExpiresAt])
}

// Emitted whenever revalidation finds a materially different routing outcome.
// Powers the executionIntegrity panel in the dashboard.
model ExecutionDriftEvent {
  id             String  @id @default(cuid())
  organizationId String?

  decisionLeaseId String
  createdAt       DateTime @default(now())

  originalRegion    String
  newRegion         String
  originalIntensity Int
  newIntensity      Int
  reason            String

  @@index([organizationId, createdAt])
  @@index([decisionLeaseId])
}
