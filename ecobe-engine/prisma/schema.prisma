generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// CARBON INTENSITY DATA
// ============================================================================

model CarbonIntensity {
  id        String   @id @default(cuid())

  region    String   // e.g., "US-CAL-CISO", "FR", "DE"

  // Carbon metrics
  carbonIntensity      Int      // gCO2eq/kWh
  fossilFuelPercentage Float?
  renewablePercentage  Float?

  // Source
  source    String   @default("ELECTRICITY_MAPS")

  // Timestamp
  timestamp DateTime

  // Metadata
  isEstimated Boolean  @default(false)
  metadata    Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([region, timestamp])
  @@index([timestamp])
  @@unique([region, timestamp], name: "region_timestamp")
  @@unique([region, timestamp, source], name: "region_timestamp_source")
}

// ============================================================================
// WORKLOAD ROUTING
// ============================================================================

model WorkloadRequest {
  id        String   @id @default(cuid())

  // Request details
  requestVolume Int
  workloadType  String   // "inference", "training", "batch"
  modelSize     String?  // "mixtral-70b", "llama-3-8b", etc.

  // Routing
  regionTargets String[] // Preferred regions

  // Constraints
  carbonBudget     Float?  // Max gCO2eq allowed
  deadlineStart    DateTime?
  deadlineEnd      DateTime?
  maxLatencyMs     Int?

  // Hardware mix (optional)
  hardwareCpu      Float?  @default(0.6)
  hardwareGpu      Float?  @default(0.3)
  hardwareTpu      Float?  @default(0.1)

  // Results
  selectedRegion   String?
  estimatedCO2     Float?
  actualCO2        Float?

  // Status
  status    WorkloadStatus @default(PENDING)

  // Timestamps
  createdAt DateTime @default(now())
  completedAt DateTime?

  routingDecisions RoutingDecision[]

  @@index([status])
  @@index([createdAt])
}

enum WorkloadStatus {
  PENDING
  ROUTED
  EXECUTING
  COMPLETED
  FAILED
}

model RoutingDecision {
  id        String   @id @default(cuid())

  workloadRequestId String
  workloadRequest   WorkloadRequest @relation(fields: [workloadRequestId], references: [id], onDelete: Cascade)

  region            String
  rank              Int      // 1 = best choice

  // Metrics at decision time
  carbonIntensity   Int      // gCO2eq/kWh
  estimatedCO2      Float    // Total gCO2eq
  estimatedLatency  Int?     // ms
  estimatedCost     Float?   // USD

  // Score components
  carbonScore       Float
  latencyScore      Float
  costScore         Float
  overallScore      Float

  selected          Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([workloadRequestId])
  @@index([region])
}

model DashboardRoutingDecision {
  id        String   @id @default(cuid())

  createdAt DateTime @default(now())

  workloadName String?
  opName       String?

  baselineRegion String
  chosenRegion   String

  zoneBaseline String?
  zoneChosen   String?

  carbonIntensityBaselineGPerKwh Int?
  carbonIntensityChosenGPerKwh   Int?

  estimatedKwh Float?
  co2BaselineG Float?
  co2ChosenG   Float?

  reason String?

  latencyEstimateMs Int?
  latencyActualMs   Int?

  fallbackUsed        Boolean @default(false)
  dataFreshnessSeconds Int?
  requestCount         Int   @default(1)

  meta Json @default("{}")

  @@index([createdAt])
  @@index([baselineRegion])
  @@index([chosenRegion])
}

// ============================================================================
// CARBON COMMAND (Decision Engine)
// ============================================================================

model CarbonCommand {
  id        String   @id @default(cuid())

  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  requestPayload Json

  workloadType  String?
  modelFamily   String?
  executionMode String?

  mode      CarbonCommandMode   @default(IMMEDIATE)
  status    CarbonCommandStatus @default(PENDING)

  candidateWindowHours Int?
  allowTimeShifting    Boolean  @default(true)
  allowCrossRegion     Boolean  @default(true)
  requireCreditCoverage Boolean @default(false)

  selectedRegion        String?
  selectedStartAt       DateTime?
  fallbackRegion        String?
  expectedCarbonIntensity Int?
  expectedLatencyMs     Int?
  expectedCostIndex     Float?
  estimatedEmissionsKgCo2e Float?
  estimatedSavingsKgCo2e Float?
  confidence            Float?

  summaryReason   String?
  tradeoffSummary String?

  decisionId      String?

  metadata Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trace    CarbonCommandTrace?
  outcomes CarbonCommandOutcome[]
  embeddingIndex WorkloadEmbeddingIndex? @relation("CarbonCommandEmbedding")
  adaptiveRun    AdaptiveRunLog?         @relation("CarbonCommandAdaptiveRun")

  @@index([orgId])
  @@index([mode])
  @@index([status])
  @@index([selectedRegion])
  @@index([workloadType])
  @@index([modelFamily])
}

model CarbonCommandTrace {
  id        String   @id @default(cuid())

  commandId String   @unique
  command   CarbonCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)

  scoringModel   String
  weights        Json
  inputs         Json
  environment    Json
  candidates     Json
  rejected       Json
  selection      Json
  traceJson      Json

  createdAt DateTime @default(now())
}

model CarbonCommandOutcome {
  id        String   @id @default(cuid())

  commandId String   @unique
  command   CarbonCommand @relation(fields: [commandId], references: [id], onDelete: Cascade)

  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  actualRegion          String
  actualStartAt         DateTime
  actualEndAt           DateTime?
  actualLatencyMs       Int?
  actualGpuHours        Float?
  actualCpuHours        Float?
  actualMemoryGb        Float?
  actualCarbonIntensity Float?
  actualEmissionsKgCo2e Float?
  actualCostUsd         Float?
  costIndexObserved     Float?

  measurementSource CarbonMeasurementSource @default(ESTIMATED)
  providerExecutionId String? @unique

  predictedEmissionsKgCo2e Float?
  predictedLatencyMs       Int?
  predictedCostIndex       Float?

  emissionsVarianceKg   Float?
  emissionsVariancePct  Float?
  latencyVarianceMs     Int?
  latencyVariancePct    Float?
  costVariancePct       Float?
  regionMatch           Boolean @default(false)
  slaMet                Boolean?
  fallbackTriggered     Boolean? @default(false)
  completed             Boolean  @default(false)
  predictionQuality     PredictionQuality @default(MEDIUM)

  comparisonJson Json @default("{}")
  learningSignals Json @default("{}")
  metadata        Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([actualRegion])
}

enum CarbonCommandMode {
  IMMEDIATE
  SCHEDULED
  ADVISORY
}

enum CarbonCommandStatus {
  PENDING
  RECOMMENDED
  EXECUTED
  FAILED
}

enum CarbonMeasurementSource {
  ESTIMATED
  PROVIDER_REPORTED
  METERED
}

enum PredictionQuality {
  HIGH
  MEDIUM
  LOW
}

// ============================================================================
// ORGANIZATIONS & USAGE
// ============================================================================

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum OrgPlanTier {
  FREE
  GROWTH
  ENTERPRISE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  apiKey    String   @unique
  billingEmail String?
  planTier  OrgPlanTier        @default(FREE)
  status    OrganizationStatus @default(ACTIVE)
  monthlyCommandLimit Int      @default(1000)
  enforceCreditCoverage Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commands CarbonCommand[]
  outcomes CarbonCommandOutcome[]
  usageCounters OrgUsageCounter[]
}

model OrgUsageCounter {
  id        String   @id @default(cuid())
  orgId     String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  periodStart DateTime
  commandCount Int    @default(0)
  estimatedEmissionsKg Float @default(0)
  lastCommandAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, periodStart])
  @@index([orgId])
}

// ============================================================================
// CARBON COMMAND ACCURACY (Daily Aggregates)
// ============================================================================

model CarbonCommandAccuracyDaily {
  id        String   @id @default(cuid())

  date DateTime
  orgId String
  workloadType String?
  region       String?

  totalCommands          Int    @default(0)
  regionMatchCount       Int    @default(0)
  avgEmissionsVariancePct Float  @default(0)
  avgLatencyVariancePct   Float  @default(0)
  avgCostVariancePct      Float  @default(0)
  highQualityCount       Int    @default(0)
  mediumQualityCount     Int    @default(0)
  lowQualityCount        Int    @default(0)
  estimatedSavingsKgCo2e  Float  @default(0)
  verifiedSavingsKgCo2e   Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, orgId, workloadType, region])
}

// ============================================================================
// WORKLOAD EMBEDDING INDEX
// ============================================================================

model WorkloadEmbeddingIndex {
  id        String   @id @default(cuid())
  commandId String   @unique
  orgId     String
  vectorId  String?

  workloadType String?
  modelFamily  String?
  executionMode String?
  gpuHoursBucket String?
  gpuHours     Float?
  cpuHours     Float?
  memoryGb     Float?
  region       String?
  carbonIntensity Float?
  emissionsKgCo2e Float?
  savingsKgCo2e   Float?
  latencyMs       Int?

  createdAt DateTime @default(now())

  command CarbonCommand @relation("CarbonCommandEmbedding", fields: [commandId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([workloadType])
  @@index([region])
}

// ============================================================================
// ADAPTIVE OPTIMIZATION
// ============================================================================

model AdaptiveProfile {
  id        String   @id @default(cuid())
  orgId     String
  workloadType String?
  modelFamily  String?
  region       String?

  weightModifiersJson        Json @default("{}")
  regionAdjustmentsJson      Json @default("{}")
  executionModeAdjustmentsJson Json @default("{}")
  confidenceModifiersJson    Json @default("{}")

  lastUpdatedAt DateTime @default(now())

  @@unique([orgId, workloadType, modelFamily, region])
}

model AdaptiveSignal {
  id        String   @id @default(cuid())
  orgId     String
  signalType String
  workloadType String?
  modelFamily  String?
  region       String?
  metric       String
  value        Float
  threshold    Float?
  details      Json   @default("{}")
  createdAt    DateTime @default(now())

  @@index([orgId])
  @@index([signalType])
}

model AdaptiveRunLog {
  id        String   @id @default(cuid())
  commandId String   @unique
  orgId     String

  baseScoreJson       Json @default("{}")
  adjustmentsJson     Json @default("{}")
  finalScoreJson      Json @default("{}")
  reasoningJson       Json @default("{}")

  createdAt DateTime @default(now())

  command CarbonCommand @relation("CarbonCommandAdaptiveRun", fields: [commandId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ============================================================================
// CARBON FORECASTING (ML Model)
// ============================================================================

model CarbonForecast {
  id        String   @id @default(cuid())

  region    String

  // Forecast
  forecastTime      DateTime
  predictedIntensity Int     // gCO2eq/kWh
  confidence         Float   // 0.0 - 1.0

  // Model info
  modelVersion      String  @default("v1.0")
  features          Json    @default("{}")

  // Actual (for training)
  actualIntensity   Int?
  error             Float?

  createdAt DateTime @default(now())

  @@index([region, forecastTime])
  @@index([forecastTime])
  @@unique([region, forecastTime], name: "region_forecastTime")
}

model ForecastRefresh {
  id        String   @id @default(cuid())

  region    String
  refreshedAt DateTime @default(now())

  recordsIngested    Int      @default(0)
  forecastsGenerated Int      @default(0)
  status             ForecastRefreshStatus @default(SUCCESS)
  message            String?

  createdAt DateTime @default(now())

  @@index([region, refreshedAt])
  @@index([refreshedAt])
}

enum ForecastRefreshStatus {
  SUCCESS
  FAILURE
}

// ============================================================================
// CARBON CREDITS & TRACKING
// ============================================================================

model CarbonCredit {
  id        String   @id @default(cuid())

  organizationId String?

  amountCO2      Float
  provider       String
  priceUsd       Float
  certificateUrl String?

  status     CarbonCreditStatus @default(ACTIVE)
  purchasedAt DateTime          @default(now())
  retiredAt   DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([status])
  @@index([purchasedAt])
}

enum CarbonCreditStatus {
  ACTIVE
  RETIRED
}

model EmissionLog {
  id        String   @id @default(cuid())

  organizationId   String?
  workloadRequestId String?

  emissionCO2 Float
  offsetCO2   Float @default(0)

  region    String
  source    String
  timestamp DateTime

  metadata  Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([workloadRequestId])
  @@index([region, timestamp])
  @@index([timestamp])
}

// ============================================================================
// DEKES INTEGRATION
// ============================================================================

model DekesWorkload {
  id        String   @id @default(cuid())

  // DEKES query info
  dekesQueryId      String?
  dekesRunId        String?
  queryString       String?

  // Workload characteristics
  estimatedQueries  Int
  estimatedResults  Int

  // Carbon optimization
  carbonBudget      Float?   // gCO2eq
  scheduledTime     DateTime?

  // Selected routing
  selectedRegion    String?
  actualCO2         Float?

  // Status
  status            String   @default("PENDING")

  createdAt DateTime @default(now())
  completedAt DateTime?

  @@index([status])
  @@index([dekesQueryId])
}

// ============================================================================
// REGION METADATA
// ============================================================================

model Region {
  id        String   @id @default(cuid())

  code      String   @unique  // "US-CAL-CISO", "FR", etc.
  name      String            // "California", "France"
  country   String

  // Characteristics
  typicalLatencyMs  Int?
  costPerKwh        Float?
  availableHardware String[] @default([])

  // Grid mix
  renewableCapacity Float?   // %
  avgCarbonIntensity Int?    // gCO2eq/kWh

  // Availability
  enabled   Boolean  @default(true)

  metadata  Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model DailyMetrics {
  id        String   @id @default(cuid())

  date      DateTime @unique

  // Workload stats
  totalWorkloads    Int     @default(0)
  totalCO2Grams     Float   @default(0)
  totalEnergyKwh    Float   @default(0)

  // Savings
  savedCO2Grams     Float   @default(0)  // vs baseline
  savedCostUsd      Float   @default(0)

  // Avg metrics
  avgCarbonIntensity Float?

  createdAt DateTime @default(now())

  @@index([date])
}

// ============================================================================
// INTEGRATION HEALTH METRICS
// ============================================================================

model IntegrationMetric {
  id             String   @id @default(cuid())

  source         String   @unique
  successCount   Int      @default(0)
  failureCount   Int      @default(0)
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  lastError      String?
  lastErrorCode  String?
  lastErrorAt    DateTime?
  lastLatencyMs  Float?
  totalLatencyMs Float    @default(0)
  latencySamples Int      @default(0)
  latencyP95Ms   Float?
  alertActive    Boolean  @default(false)
  alertMessage   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model IntegrationEvent {
  id         String   @id @default(cuid())
  source     String
  success    Boolean
  durationMs Float?
  statusCode Int?
  errorCode  String?
  message    String?
  createdAt  DateTime @default(now())

  @@index([source, createdAt])
  @@index([source, success, createdAt])
}

// ============================================================================
// WORKLOAD DECISION OUTCOMES
// ============================================================================

model WorkloadDecisionOutcome {
  id          String   @id @default(uuid())
  workloadId  String
  region      String?
  carbonSaved Float
  latency     Float
  cost        Float
  success     Boolean
  createdAt   DateTime @default(now())

  @@index([workloadId])
  @@index([createdAt])
}
